{
  "name": "adcet-alumni-backend",
  "version": "0.1.0",
  "private": true,
  "description": "ADCET Alumni Portal — Express + Prisma + MinIO backend",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -e .env.development -- tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "prisma:deploy": "dotenv -e .env.development -- prisma migrate deploy",
    "prisma:studio": "dotenv -e .env.development -- prisma studio",
    "seed": "dotenv -e .env.development -- tsx prisma/seed.ts",
    "db:setup": "npm run prisma:migrate -- --name init && npm run seed",
    "openapi:serve": "echo 'Swagger UI mounted at /api/docs when server runs'"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.665.0",
    "@aws-sdk/s3-request-presigner": "^3.665.0",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.4",
    "@types/swagger-ui-express": "^4.1.6",
    "dotenv-cli": "^7.4.4",
    "pino-pretty": "^11.2.2",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
