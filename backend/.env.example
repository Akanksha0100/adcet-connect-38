# === Server ===
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# === Database ===
DATABASE_URL=postgresql://adcet:adcet@localhost:5432/adcet_alumni?schema=public

# === JWT ===
JWT_ACCESS_SECRET=change-me-32-chars-minimum-secret
JWT_REFRESH_SECRET=change-me-32-chars-minimum-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# === Storage (minio | s3 | local) ===
STORAGE_DRIVER=minio
STORAGE_BUCKET=adcet-alumni
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/adcet-alumni

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL=900

LOCAL_STORAGE_DIR=./uploads