# ============================================================================
# ADCET Alumni Portal — Environment Configuration
# Copy this file to `.env.development` for local dev.
# Never commit real secrets.
# ============================================================================

# === Server ===
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:8080
LOG_LEVEL=info

# === Database ===
DATABASE_URL=postgresql://adcet:adcet@localhost:5433/adcet_alumni?schema=public

# === JWT ===
JWT_ACCESS_SECRET=change-me-32-chars-minimum-secret
JWT_REFRESH_SECRET=change-me-32-chars-minimum-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# === Storage (minio | s3 | local) ===
STORAGE_DRIVER=minio
STORAGE_BUCKET=adcet-alumni
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/adcet-alumni

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL=900

LOCAL_STORAGE_DIR=./uploads

# === Email / SMTP ===
# Leave SMTP_HOST empty to use console-only transport (emails printed to terminal).
# Set SMTP_HOST to enable real SMTP delivery (e.g. Gmail, Mailtrap, etc.).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ADCET Alumni Portal" <noreply@adcet.in>

# === API Base URL (used in email RSVP links) ===
API_BASE_URL=http://localhost:4000/api/v1

# === OAuth / SSO ===
OAUTH_REDIRECT_BASE_URL=http://localhost:4000/api/v1/auth/oauth
OAUTH_SUCCESS_REDIRECT=http://localhost:8080/auth/callback

# Google — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === Payments (Razorpay) — https://dashboard.razorpay.com/app/keys ===
# Leave empty to disable donations (order/verify endpoints return 501).
# Use rzp_test_* keys for testing; switch to rzp_live_* in production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret configured in Razorpay Dashboard → Settings → Webhooks
# (subscribe to payment.captured; point it at /api/v1/donations/webhook).
RAZORPAY_WEBHOOK_SECRET=

# Printed on donation receipts (PDF + email).
ORG_NAME=Annasaheb Dange College of Engineering & Technology, Ashta
ORG_ADDRESS=Ashta, Dist. Sangli, Maharashtra 416301
